# envs/free/terraform.tfvars.example
# Copy to terraform.tfvars and fill in your values
# NEVER commit terraform.tfvars to git

project        = "rpg-platform"
aws_region     = "us-east-1"
aws_account_id = "123456789012"  # Your 12-digit AWS account ID

# Generate: ssh-keygen -t ed25519 -C "rpg-platform"
# Then paste contents of ~/.ssh/id_ed25519.pub
public_key = "ssh-ed25519 AAAA...your-public-key... your-email"

# Restrict to your IP: curl ifconfig.me
ssh_allowed_cidrs = ["YOUR.IP.ADDRESS.HERE/32"]

# Generate strong passwords: openssl rand -base64 32
db_password = "CHANGE_ME_strong_random_password"
db_name     = "rpgplatform"
db_user     = "rpgadmin"
turn_secret = "CHANGE_ME_another_strong_random_secret"

# Leave as localhost until you have a domain
domain = "localhost"

cors_allowed_origins = [
  "https://your-app.vercel.app",
  "http://localhost:3000",
  "http://localhost:3001"
]
